{
  "name": "playwright-learning",
  "version": "1.0.0",
  "description": "Production-ready Playwright TypeScript test automation framework",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:unit": "playwright test --project=unit",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=chromium tests/ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:pr": "playwright test --project=unit && playwright test --project=api && playwright test --project=chromium --grep @smoke",
    "test:nightly": "playwright test --grep @regression",
    "test:shard": "playwright test",
    "test:shard:regression": "playwright test --grep @regression",
    "test:mock": "playwright test --grep @mock --project=api-mock --project=chromium-mock",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:dev": "cross-env TEST_ENV=dev playwright test",
    "test:qa": "cross-env TEST_ENV=qa playwright test",
    "test:staging": "cross-env TEST_ENV=staging playwright test",
    "test:allure": "cross-env ALLURE_REPORT=true playwright test",
    "report": "playwright show-report reports/html",
    "report:allure": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:allure:open": "npm run report:allure && allure open reports/allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.3",
    "allure-playwright": "^3.10.1",
    "allure-commandline": "^2.36.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-playwright": "^2.2.0",
    "msw": "^2.14.6",
    "prettier": "^3.5.3",
    "testcontainers": "^12.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "overrides": {
    "undici": "6.21.3"
  }
}
